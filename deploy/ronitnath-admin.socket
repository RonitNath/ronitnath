[Unit]
Description=ronitnath admin listen socket

[Socket]
# systemd holds this socket across service restarts, so connections arriving
# during a deploy's restart gap queue in the kernel instead of being refused.
# Keep the address in sync with ADMIN_BIND_ADDR in ronitnath-admin.service.
ListenStream=100.88.31.199:3131
# The NetBird mesh address may not exist yet when sockets come up at boot.
FreeBind=true

[Install]
WantedBy=sockets.target
