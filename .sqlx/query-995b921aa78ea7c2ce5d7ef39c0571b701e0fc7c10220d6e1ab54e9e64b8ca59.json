  "query": "SELECT al.id as \"id: i64\", al.at,\n                      i.display_name as identity_display_name,\n                      al.action, al.entity, al.entity_id, al.detail\n               FROM audit_log al\n               LEFT JOIN identities i ON i.id = al.identity_id\n               WHERE al.account_id = ?1\n               ORDER BY al.id DESC\n               LIMIT ?2",
